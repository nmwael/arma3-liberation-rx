{
  "name": "Arma 3 Liberation RX",
  "description": "6-player co-op Liberation RX server for Pterodactyl (Discord voice, no TFAR)",
  "author": "nmwael",
  "version": "1.1.0",
  "startup": "./{{SERVER_BINARY}} -ip=0.0.0.0 -port={{SERVER_PORT}} -profiles=./serverprofile -bepath=./ -cfg=basic.cfg -config=server.cfg -mod=\"{{CLIENT_MODS}}\" -serverMod=\"{{SERVERMODS}}\" \"{{STARTUP_PARAMS}}\"",
  "script": {
    "privileged": false,
    "install": {
      "container": "ghcr.io/ptero-eggs/installers:debian",
      "entrypoint": "/bin/bash",
      "script": "#!/bin/bash\napt -y update\napt -y --no-install-recommends install curl lib32gcc-s1 ca-certificates\ncd /tmp\nmkdir -p /mnt/server/steamcmd /mnt/server/steamapps\ncurl -sSL -o steamcmd.tar.gz https://steamcdn-a.akamaihd.net/client/installer/steamcmd_linux.tar.gz\ntar -xzvf steamcmd.tar.gz -C /mnt/server/steamcmd\ncd /mnt/server/steamcmd\nchown -R root:root /mnt\nexport HOME=/mnt/server\n./steamcmd.sh +force_install_dir /mnt/server \"+login \\\"${STEAM_USER}\\\" \\\"${STEAM_PASS}\\\"\" +app_update ${STEAMCMD_APPID} ${STEAMCMD_EXTRA_FLAGS} validate +quit\nmkdir -p /mnt/server/.steam/sdk{32,64}\ncp -v linux32/steamclient.so /mnt/server/.steam/sdk32/steamclient.so\ncp -v linux64/steamclient.so /mnt/server/.steam/sdk64/steamclient.so\ncd /mnt/server/\n[[ -f basic.cfg ]] || curl -sSLO ${BASIC_URL}\n[[ -f server.cfg ]] || curl -sSLO ${BASIC_URL%/*}/server.cfg\nchmod 644 basic.cfg server.cfg\necho \"Installation completed...\""
    }
  },
  "variables": [
    {
      "name": "Steam Username",
      "description": "Steam account for installation (does not need to own Arma 3)",
      "env_variable": "STEAM_USER",
      "default_value": "your_steam_username",
      "user_viewable": false,
      "user_editable": false,
      "rules": "required|string"
    },
    {
      "name": "Steam Password",
      "description": "Steam account password (Steam Guard must be OFF)",
      "env_variable": "STEAM_PASS",
      "default_value": "your_steam_password",
      "user_viewable": false,
      "user_editable": false,
      "rules": "required|string"
    },
    {
      "name": "Server Binary",
      "description": "Server binary to use (64-bit recommended)",
      "env_variable": "SERVER_BINARY",
      "default_value": "arma3server_x64",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|in:arma3server,arma3server_x64,arma3serverprofiling,arma3serverprofiling_x64"
    },
    {
      "name": "Server Name",
      "description": "Server hostname shown in browser",
      "env_variable": "SERVER_NAME",
      "default_value": "Liberation RX - 6 Player Co-op",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|max:64"
    },
    {
      "name": "Server Password",
      "description": "Password to join the server",
      "env_variable": "SERVER_PASSWORD",
      "default_value": "changeme",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|max:32"
    },
    {
      "name": "Admin Password",
      "description": "Admin login password (#login)",
      "env_variable": "ADMIN_PASSWORD",
      "default_value": "admin123",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|string|max:32"
    },
    {
      "name": "Max Players",
      "description": "Maximum player slots (6 players + headroom)",
      "env_variable": "MAX_PLAYERS",
      "default_value": "10",
      "user_viewable": true,
      "user_editable": true,
      "rules": "required|integer|min:2|max:64"
    },
    {
      "name": "Game Port",
      "description": "Game port (allocated by Pterodactyl)",
      "env_variable": "SERVER_PORT",
      "default_value": "2302",
      "user_viewable": true,
      "user_editable": false,
      "rules": "required|integer|min:1024|max:65535"
    },
    {
      "name": "Modlist File",
      "description": "Filename for exported Arma 3 Launcher modlist",
      "env_variable": "MOD_FILE",
      "default_value": "modlist.html",
      "user_viewable": true,
      "user_editable": true,
      "rules": "nullable|string"
    },
    {
      "name": "Automatic Updates",
      "description": "Check for server/mod updates on startup",
      "env_variable": "UPDATE_SERVER",
      "default_value": "1",
      "user_viewable": true,
      "user_editable": true,
      "rules": "boolean"
    },
    {
      "name": "Extra Startup Parameters",
      "description": "Additional Arma 3 startup parameters",
      "env_variable": "STARTUP_PARAMS",
      "default_value": "-noLogs",
      "user_viewable": true,
      "user_editable": true,
      "rules": "string|nullable"
    }
  ],
  "ports": [
    {
      "name": "Game",
      "port_variable": "SERVER_PORT",
      "protocol": "udp",
      "default": 2302
    },
    {
      "name": "Steam Query",
      "port_variable": "STEAM_QUERY_PORT",
      "protocol": "udp",
      "default": 2303
    },
    {
      "name": "Steam Master",
      "port_variable": "STEAM_MASTER_PORT",
      "protocol": "udp",
      "default": 2304
    },
    {
      "name": "BattlEye",
      "port_variable": "BATTLEYE_PORT",
      "protocol": "udp",
      "default": 2306
    }
  ],
  "mounts": [],
  "environment": {
    "STEAM_QUERY_PORT": "2303",
    "STEAM_MASTER_PORT": "2304",
    "BATTLEYE_PORT": "2306"
  }
}
